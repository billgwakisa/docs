{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Bridge Documentation",
  "colors": {
    "primary": "#15803d",
    "light": "#07C983",
    "dark": "#18181b"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "getting-started",
              "onboarding",
              "authentication"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/conventions",
              "concepts/errors"
            ]
          },
          {
            "group": "AI agents",
            "pages": [
              "mcp"
            ]
          }
        ]
      },
      {
        "tab": "Recipes",
        "groups": [
          {
            "group": "Build a flow",
            "pages": [
              "recipes/kyc-onboarding",
              "recipes/wallets",
              "recipes/lending",
              "recipes/bnpl",
              "recipes/collections"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "/api-reference/openapi.json"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.bridge.usereli.tech",
          "icon": "window"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@usereli.tech",
          "icon": "headset"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@usereli.tech"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.bridge.usereli.tech"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "mcp", "cursor", "vscode"]
  },
  "footer": {
    "socials": {
      "website": "https://usereli.tech"
    }
  }
}
